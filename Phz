local function GetClosestPlayer()
    local target = nil; local dist = AimbotFOV
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            if IgnoreBots and (p.UserId <= 0 or p.Character:FindFirstChild("Bot")) then continue end
            if VisibleCheck and not MagnetEnabled and not IsVisible(p.Character.Head) then continue end
            local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
            if vis then
                local d
                if AimbotLegitEnabled then
                    d = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                else
                    d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude
                end
                if d < dist then dist = d; target = p end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    UpdateESP()
    FPS = math.floor(1 / RunService.RenderStepped:Wait()); FPSLabel.Text = "FPS: " .. FPS
    local target = GetClosestPlayer()
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            if AimbotEnabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                local targetPart = target.Character.Head
                if AlwaysHeadshot then
                    targetPart = target.Character:FindFirstChild("Head") or target.Character.Head
                end
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPart.Position), 0.2)
            end
        if MagnetEnabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            target.Character.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -10)
        end
    end
    if TeleportKillEnabled then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                LocalPlayer.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3); task.wait(0.1); break
            end
        end
    end
    if SpinBotEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(SpinSpeed), 0)
    end
    if NoclipEnabled and LocalPlayer.Character then
        for _, p in pairs(LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
    end
end)

